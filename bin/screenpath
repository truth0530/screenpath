#!/usr/bin/env bash
#
# screenpath — capture a screen region and copy the saved file PATH to the clipboard.
#
# Most macOS screenshot tools copy the IMAGE to the clipboard. screenpath copies the
# file PATH instead, so you can paste it straight into terminal / CLI / AI-agent
# workflows (tmux, Claude Code, etc.) where an image is referenced by its path.
#
# https://github.com/truth0530/screenpath
# MIT License

set -uo pipefail

VERSION="0.1.2"

# Defaults (override with flags or environment variables)
DIR="${SCREENPATH_DIR:-$HOME/Screenshots}"
PREFIX="${SCREENPATH_PREFIX:-shot}"
MODE="region"   # region | window | full
COPY="path"     # path | image | none
FORMAT="raw"    # raw | quote | url  (how the path is written to the clipboard)
# Maintain a fixed "latest" symlink to each capture (also enabled by --link).
LINK="${SCREENPATH_LINK:+1}"; LINK="${LINK:-0}"
# Quiet by default. Enable a macOS notification with --notify or SCREENPATH_NOTIFY=1.
NOTIFY="${SCREENPATH_NOTIFY:+1}"; NOTIFY="${NOTIFY:-0}"
# The capture binary (overridable for testing only).
SCREENCAPTURE="${SCREENPATH_SCREENCAPTURE:-/usr/sbin/screencapture}"

err() { printf '%s\n' "$*" >&2; }

print_version() {
  printf 'screenpath %s\n' "$VERSION"
}

print_help() {
  cat <<'EOF'
screenpath — capture a screen region and copy the file PATH to the clipboard.

USAGE:
  screenpath [options]
  screenpath install-raycast [DIR]   Install the bundled Raycast script command

OPTIONS:
  -d, --dir DIR       Save screenshots here (default: ~/Screenshots, or $SCREENPATH_DIR)
  -p, --prefix NAME   Filename prefix (default: shot, or $SCREENPATH_PREFIX)
      --tmp           Save to a temp dir ($TMPDIR/screenpath) instead of ~/Screenshots
  -w, --window        Capture a window instead of dragging a region
  -f, --full          Capture the whole screen (no selection)
  -i, --image         Copy the IMAGE to the clipboard instead of the path
  -Q, --quote         Copy a shell-quoted path (safe to paste even with spaces)
  -u, --url           Copy a file:// URL instead of a plain path
  -l, --link          Point a fixed "latest" symlink at this shot
                        ($DIR/latest.png, or $SCREENPATH_LINK)
  -n, --no-clip       Don't touch the clipboard; just print the path
      --notify        Show a macOS "Path copied" notification (off by default)
      --setup         Print hotkey setup instructions (Raycast / Shortcuts / skhd)
  -v, --version       Print version
  -h, --help          Show this help

By default screenpath copies ONLY the file path, leaving image-copy to your normal
screenshot tool (e.g. Shottr). The path is printed to stdout as well.

If your screenshots folder contains spaces, use --quote so the pasted path stays
a single shell argument, or --url for apps that expect a file:// URL.

EXIT STATUS:
  0  a path was captured and printed (clipboard updated unless --no-clip),
     OR the user cancelled the selection (in which case nothing is printed)
  1  a capture/clipboard/permission failure (message on stderr)
  2  a usage error (unknown option, missing value, conflicting flags)
A script can treat empty stdout as "nothing captured".
EOF
}

print_setup() {
  cat <<'EOF'
screenpath puts a `screenpath` command on your PATH, but a global hotkey must be
bound by you — macOS does not let a CLI register one programmatically. Pick one:

[1] Raycast (recommended — smoothest)
    - In Raycast, register a Script Commands directory FIRST:
        Settings > Extensions > Script Commands > Add Directories
      (Raycast only scans directories you have added — there is no default.)
    - Install the bundled command into that exact directory:
        screenpath install-raycast <that-directory>
    - Then assign a Hotkey to "Screenpath" in Raycast.

[2] macOS Shortcuts (built-in, no extra app)
    - Shortcuts.app > New Shortcut > add "Run Shell Script" action:
        screenpath
      (If "command not found", use the full path: which screenpath)
    - Shortcut > Details > Add Keyboard Shortcut, then press your key.

[3] skhd (fully scriptable, power users)
    - brew install koekeishiya/formulae/skhd
    - Add to ~/.config/skhd/skhdrc:
        cmd + shift + 5 : screenpath
    - skhd --start-service   (grant Accessibility permission when prompted)

PERMISSION: the FIRST capture will ask for "Screen Recording" permission for whatever
app launches screenpath (Raycast / Shortcuts / Terminal). Grant it in
System Settings > Privacy & Security > Screen Recording, then try again.
EOF
}

# Wrap a string in single quotes, safely escaping any embedded single quotes,
# so the result is a single, paste-safe shell word.
shell_quote() {
  local s=$1 q=\'
  s=${s//$q/$q\\$q$q}   # every ' becomes '\''
  printf '%s' "$q$s$q"
}

# Percent-encode a path into a file:// URL. Iterates byte-by-byte under the C
# locale so multi-byte UTF-8 (e.g. Korean) is encoded correctly per RFC 3986.
to_file_url() {
  local path=$1 out='' i ch code
  local LC_ALL=C LC_CTYPE=C
  for (( i = 0; i < ${#path}; i++ )); do
    ch=${path:i:1}
    case $ch in
      [a-zA-Z0-9._~/-]) out+=$ch ;;
      *) printf -v code '%d' "'$ch"; printf -v ch '%%%02X' "$(( code & 255 ))"; out+=$ch ;;
    esac
  done
  printf 'file://%s' "$out"
}

# Render a path according to $FORMAT (raw | quote | url).
format_path() {
  case "$FORMAT" in
    quote) shell_quote "$1" ;;
    url)   to_file_url "$1" ;;
    *)     printf '%s' "$1" ;;
  esac
}

# Copy the bundled Raycast script command into a Raycast scripts directory.
# Raycast's folder is user-configured, so we ask for it rather than guess.
install_raycast() {
  local target=$1 src='' self_dir c
  self_dir="$(cd "$(dirname "$0")" && pwd)"
  for c in "$self_dir/../share/screenpath/raycast/screenpath.sh" \
           "$self_dir/../extras/raycast/screenpath.sh"; do
    [ -f "$c" ] && { src="$c"; break; }
  done
  if [ -z "$src" ]; then
    err "screenpath: could not find the bundled Raycast script near $self_dir"
    return 1
  fi
  if [ -z "$target" ]; then
    cat <<'EOF'
Usage: screenpath install-raycast <raycast-scripts-dir>

Raycast has no default scripts folder — it only scans directories you add under
  Raycast Settings > Extensions > Script Commands > Add Directories
Add one there first, then pass that exact path, e.g.:
  screenpath install-raycast ~/raycast-scripts

After it is copied, open Raycast and assign a Hotkey to "Screenpath".
EOF
    return 0
  fi
  if [ ! -d "$target" ]; then
    err "screenpath: directory does not exist: $target"
    return 1
  fi
  if ! cp "$src" "$target/screenpath.sh"; then
    err "screenpath: failed to copy into $target"
    return 1
  fi
  chmod +x "$target/screenpath.sh" 2>/dev/null || true
  printf 'Installed Raycast script: %s/screenpath.sh\n' "$target"
  printf 'Open Raycast and assign a Hotkey to "Screenpath".\n'
}

# Best-effort 3-digit millisecond, or empty if unavailable.
# GNU date supports %3N; macOS date does not, so fall back to perl (preinstalled).
capture_ms() {
  local ms
  ms="$(date +%3N 2>/dev/null)"                 # GNU date
  case "$ms" in ''|*[!0-9]*) ms='' ;; esac
  if [ -z "$ms" ]; then                          # macOS: try perl, then a random tiebreaker
    ms="$(perl -MTime::HiRes=time -e 'my $t=Time::HiRes::time; printf "%03d", ($t-int($t))*1000' 2>/dev/null)"
  fi
  case "$ms" in ''|*[!0-9]*) ms="$(printf '%03d' "$(( RANDOM % 1000 ))")" ;; esac
  printf '%s' "$ms"
}

# Pick a capture path that does not overwrite an existing file.
# Clean base "$prefix-$ts.png"; on collision add a millisecond, then a -N counter.
pick_path() {
  local dir=$1 prefix=$2 ts=$3 ms n
  if [ ! -e "$dir/$prefix-$ts.png" ]; then
    printf '%s' "$dir/$prefix-$ts.png"; return
  fi
  ms="$(capture_ms)"
  if [ -n "$ms" ] && [ ! -e "$dir/$prefix-$ts-$ms.png" ]; then
    printf '%s' "$dir/$prefix-$ts-$ms.png"; return
  fi
  n=2
  while [ -e "$dir/$prefix-$ts-$n.png" ]; do n=$((n + 1)); done
  printf '%s' "$dir/$prefix-$ts-$n.png"
}

# Point a fixed symlink at the latest capture. Refuses to clobber a real file.
update_link() {
  local src=$1 link=$2
  if [ -e "$link" ] && [ ! -L "$link" ]; then
    err "screenpath: --link target exists and is not a symlink: $link"
    return 1
  fi
  ln -sf "$src" "$link"
}

# Show a macOS notification (best-effort). The text is passed as an argv item,
# never interpolated into the AppleScript source, so a filename containing quotes
# can neither break the script nor inject `do shell script`.
notify_copied() {
  osascript - "$1" >/dev/null 2>&1 <<'APPLESCRIPT' || true
on run argv
  display notification (item 1 of argv) with title "screenpath" subtitle "Path copied to clipboard"
end run
APPLESCRIPT
}

# Copy an image file to the clipboard. Filename passed as argv (no interpolation).
# Returns osascript's exit status so the caller can detect failure.
copy_image() {
  osascript - "$1" >/dev/null 2>&1 <<'APPLESCRIPT'
on run argv
  set the clipboard to (read (POSIX file (item 1 of argv)) as TIFF picture)
end run
APPLESCRIPT
}

# When sourced (e.g. by the test suite) stop here so only the helpers above load.
if (return 0 2>/dev/null); then return 0; fi

# Subcommands (must be the first argument).
if [ "${1:-}" = "install-raycast" ]; then
  shift
  install_raycast "${1:-}"
  exit $?
fi

need_value() { [ "$2" -ge 2 ] || { err "screenpath: $1 needs a value"; exit 2; }; }

fmt_count=0 copy_count=0
while [ $# -gt 0 ]; do
  case "$1" in
    -d|--dir)     need_value --dir "$#"; DIR=$2; shift 2 ;;
    -p|--prefix)  need_value --prefix "$#"; PREFIX=$2; shift 2 ;;
    --tmp)        DIR="${TMPDIR:-/tmp}/screenpath"; shift ;;
    -w|--window)  MODE="window"; shift ;;
    -f|--full)    MODE="full"; shift ;;
    -i|--image)   COPY="image"; copy_count=$((copy_count + 1)); shift ;;
    -Q|--quote)   FORMAT="quote"; fmt_count=$((fmt_count + 1)); shift ;;
    -u|--url)     FORMAT="url"; fmt_count=$((fmt_count + 1)); shift ;;
    -l|--link)    LINK=1; shift ;;
    -n|--no-clip) COPY="none"; copy_count=$((copy_count + 1)); shift ;;
    --notify)     NOTIFY=1; shift ;;
    --setup)      print_setup; exit 0 ;;
    -v|--version) print_version; exit 0 ;;
    -h|--help)    print_help; exit 0 ;;
    *) err "screenpath: unknown option '$1' (try --help)"; exit 2 ;;
  esac
done

# Reject contradictory flags rather than silently picking last-wins.
if [ "$fmt_count" -gt 1 ]; then
  err "screenpath: use only one of --quote / --url"; exit 2
fi
if [ "$copy_count" -gt 1 ]; then
  err "screenpath: use only one of --image / --no-clip"; exit 2
fi
if [ "$COPY" = "image" ] && [ "$FORMAT" != "raw" ]; then
  err "screenpath: --quote / --url do not apply to --image"; exit 2
fi

# A prefix is a filename component, not a path — reject separators so it can't
# escape $DIR ('../x') or point at a missing subdir ('sub/x').
case "$PREFIX" in
  */*) err "screenpath: --prefix / SCREENPATH_PREFIX must not contain '/'"; exit 2 ;;
esac

if ! command -v "$SCREENCAPTURE" >/dev/null 2>&1; then
  err "screenpath: '$SCREENCAPTURE' not found — this tool is macOS only."
  exit 1
fi

mkdir -p -- "$DIR" || { err "screenpath: cannot create directory: $DIR"; exit 1; }
# Resolve to an absolute path so the saved location is deterministic (hotkey
# launchers have an unpredictable cwd) and the file:// URL is well-formed.
DIR="$(cd -- "$DIR" && pwd)" || { err "screenpath: cannot resolve directory: $DIR"; exit 1; }

ts="$(date +%Y%m%d-%H%M%S)"
file="$(pick_path "$DIR" "$PREFIX" "$ts")"

# Build screencapture args by mode.
case "$MODE" in
  region) args=(-i) ;;       # interactive drag-to-select
  window) args=(-i -W) ;;    # interactive, starting in window-selection mode
  full)   args=(-m) ;;       # main display only -> exactly one predictable file
esac

# Capture stderr: screencapture exits 0 even when it fails to write, so we use
# "no file + an error message" to tell a real failure from a user cancel.
cap_err="$("$SCREENCAPTURE" ${args[@]+"${args[@]}"} "$file" 2>&1)"

if [ ! -e "$file" ]; then
  if [ -n "$cap_err" ]; then
    err "screenpath: capture failed: $cap_err"
    exit 1
  fi
  exit 0   # user cancelled the selection — nothing captured
fi

# Zero-byte file -> capture failed, almost always missing Screen Recording permission.
if [ ! -s "$file" ]; then
  rm -f "$file"
  err "screenpath: capture produced an empty file."
  err "  Grant 'Screen Recording' permission to the app launching screenpath:"
  err "  System Settings > Privacy & Security > Screen Recording"
  err "  (Run 'screenpath --setup' for details.)"
  exit 1
fi

out="$(format_path "$file")"

case "$COPY" in
  path)
    if ! printf '%s' "$out" | pbcopy; then
      err "screenpath: failed to copy to the clipboard (path saved at $file)"
      exit 1
    fi
    if [ "$NOTIFY" = "1" ]; then notify_copied "$out"; fi
    ;;
  image)
    if ! copy_image "$file"; then
      err "screenpath: failed to copy image to clipboard (path saved at $file)"
      exit 1
    fi
    ;;
  none)
    : ;;
esac

if [ "$LINK" = "1" ]; then
  update_link "$file" "${SCREENPATH_LINK:-$DIR/latest.png}" || true
fi

# Always print the path (same form as the clipboard) so it works in pipelines.
printf '%s\n' "$out"
